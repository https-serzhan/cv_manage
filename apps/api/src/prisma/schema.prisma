generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  displayName          String
  avatarUrl            String?
  isBlocked            Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  version              Int                       @default(1)
  roles                UserRole[]
  authProviderAccounts AuthProviderAccount[]
  preference           UserPreference?
  candidateProfile     CandidateProfile?
  createdPositions     Position[]                @relation("PositionCreatedBy")
  positionAccess       PositionCandidateAccess[] @relation("PositionCandidateAccessUser")
}

model Role {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())
  userRoles UserRole[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AuthProviderAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model UserPreference {
  userId    String   @id
  language  String   @default("en")
  theme     String   @default("light")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  DROPDOWN
}

enum PositionAccessMode {
  PUBLIC
  RESTRICTED
}

model AttributeCategory {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  attributes Attribute[]
}

model Attribute {
  id                 String                    @id @default(cuid())
  categoryId         String
  name               String                    @unique
  description        String?
  type               AttributeType
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  version            Int                       @default(1)
  category           AttributeCategory         @relation(fields: [categoryId], references: [id])
  options            AttributeOption[]
  candidateValues    CandidateAttributeValue[]
  positionAttributes PositionAttribute[]

  @@index([categoryId])
}

model AttributeOption {
  id              String                    @id @default(cuid())
  attributeId     String
  value           String
  sortOrder       Int
  createdAt       DateTime                  @default(now())
  attribute       Attribute                 @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  candidateValues CandidateAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
}

model CandidateProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  headline       String?
  summary        String?  @db.Text
  location       String?
  avatarImageUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  version        Int      @default(1)

  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeValues CandidateAttributeValue[]
  projects        CandidateProject[]
}

model CandidateAttributeValue {
  id                 String @id @default(cuid())
  candidateProfileId String
  attributeId        String

  stringValue      String?
  textValue        String?   @db.Text
  imageUrl         String?
  numericValue     Decimal?  @db.Decimal(18, 4)
  dateValue        DateTime? @db.Date
  periodStart      DateTime? @db.Date
  periodEnd        DateTime? @db.Date
  booleanValue     Boolean?
  selectedOptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  attribute        Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  selectedOption   AttributeOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([candidateProfileId, attributeId])
  @@index([candidateProfileId])
  @@index([attributeId])
  @@index([selectedOptionId])
}

model CandidateProject {
  id                 String    @id @default(cuid())
  candidateProfileId String
  title              String
  description        String?   @db.Text
  role               String?
  url                String?
  startDate          DateTime? @db.Date
  endDate            DateTime? @db.Date
  isCurrent          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  version            Int       @default(1)

  candidateProfile CandidateProfile      @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  tags             CandidateProjectTag[]

  @@index([candidateProfileId])
}

model ProjectTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  projects     CandidateProjectTag[]
  positionTags PositionProjectTag[]
}

model CandidateProjectTag {
  projectId String
  tagId     String
  createdAt DateTime @default(now())

  project CandidateProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     ProjectTag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
}

model Position {
  id          String             @id @default(cuid())
  title       String
  description String?            @db.Text
  accessMode  PositionAccessMode @default(PUBLIC)
  maxProjects Int?
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  version     Int                @default(1)

  createdBy       User?                     @relation("PositionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  attributes      PositionAttribute[]
  projectTags     PositionProjectTag[]
  candidateAccess PositionCandidateAccess[]

  @@index([title])
  @@index([createdById])
  @@index([accessMode])
}

model PositionAttribute {
  positionId  String
  attributeId String
  sortOrder   Int
  isRequired  Boolean  @default(true)
  createdAt   DateTime @default(now())

  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@id([positionId, attributeId])
  @@unique([positionId, sortOrder])
  @@index([attributeId])
}

model PositionProjectTag {
  positionId String
  tagId      String
  createdAt  DateTime @default(now())

  position Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)
  tag      ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([positionId, tagId])
  @@index([tagId])
}

model PositionCandidateAccess {
  positionId      String
  candidateUserId String
  createdAt       DateTime @default(now())

  position  Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  candidate User     @relation("PositionCandidateAccessUser", fields: [candidateUserId], references: [id], onDelete: Cascade)

  @@id([positionId, candidateUserId])
  @@index([candidateUserId])
}
